<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TerraRun.Pages.MenuPage"
             Title="Турниры"
             BackgroundColor="#F5F5F5">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">
            
            <Label Text="Управление турнирами"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,0,0,20"
                   TextColor="#333333" />

            <Button Text="➕ Создать турнир"
                    Clicked="OnCreateTournamentClicked"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    HeightRequest="60"
                    CornerRadius="15"
                    FontSize="18"
                    FontAttributes="Bold" />

            <Button Text="🤝 Присоединиться к турниру"
                    Clicked="OnJoinTournamentClicked"
                    BackgroundColor="Orange"
                    TextColor="White"
                    HeightRequest="60"
                    CornerRadius="15"
                    FontSize="18"
                    FontAttributes="Bold" />

            <Button Text="🏆 Мои турниры"
                    Clicked="OnMyTournamentsClicked"
                    BackgroundColor="#2196F3"
                    TextColor="White"
                    HeightRequest="60"
                    CornerRadius="15"
                    FontSize="18"
                    FontAttributes="Bold" />

            <Button Text="Назад к карте"
                    Clicked="OnBackClicked"
                    BackgroundColor="Transparent"
                    TextColor="Gray"
                    Margin="0,20,0,0"
                    FontSize="14" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
             x:Class="TerraRun.Pages.TournamentMapPage"
             Title="{Binding Tournament.Name}">

    <Grid RowDefinitions="*, Auto">
        <mapsui:MapView x:Name="MapView" Grid.Row="0" VerticalOptions="Fill" HorizontalOptions="Fill" />
        
        <VerticalStackLayout Grid.Row="1" Padding="20" Spacing="10" BackgroundColor="White">
            
            <Label Text="{Binding Tournament.Name}" HorizontalOptions="Center" FontAttributes="Bold" FontSize="18"/>
            <Label Text="{Binding Tournament.JoinCode, StringFormat='Код: {0}'}" HorizontalOptions="Center" TextColor="Gray"/>

            <Button x:Name="StartBtn"
                    Text="СТАРТ" 
                    Clicked="OnStartClicked"
                    BackgroundColor="#4CAF50" 
                    TextColor="White"
                    HeightRequest="60"
                    FontAttributes="Bold" />

            <Button Text="ЛИДЕРБОРД" 
                    Clicked="OnLeaderboardClicked"
                    BackgroundColor="#2196F3" 
                    TextColor="White" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>